

@page
@model IndexModel

<h1 class="mb-3"> Order List</h1>
<div class=" d-flex justify-content-end mb-3">
<a asp-page="Create" class="btn btn-success ">Add New Order</a>
</div>
<div class="container table-responsive">
<table class="table table-bordered table-striped table-responsive" >
<thead class="table-dark">
<tr>
<th>Id</th>
<th>Customer Name</th>
<th>Product Name</th>
<th>Quantity</th>
<th>Price</th>
<th>Order Date</th>
<th>Action</th>
</tr>
</thead>
<tbody>
@foreach (var Order in Model.Orders)
{
                <tr>
                    <td>@Order.Id</td>
                    <td>@Order.CustomerName</td>
                    <td>@Order.ProductName</td>
                    <td>@Order.Quantity</td>
                    <td>@Order.Price</td>
                    <td>@Order.OrderDate</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@Order.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-page="Delete" asp-route-id="@Order.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
}

                



</tbody>
</table>
</div>