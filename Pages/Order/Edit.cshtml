@page
@model EditModel

<h1>Update Order Form</h1>
<form method="post">
    <div class="mt-3 card mb-3 p-3">
        <input type="hidden" asp-for="Order.Id"/>
        <input type="text" placeholder="Enter Customer Name" class="form-control mb-3" asp-for="Order.CustomerName" />
        <input type="text" placeholder="Enter Product Name" class="form-control mb-3" asp-for="Order.ProductName" />
        <input type="number" placeholder="Enter Quantity" class="form-control mb-3" asp-for="Order.Quantity" />
        <input type="number" step="0.01" placeholder="Enter Price" class="form-control mb-3" asp-for="Order.Price" />
        <input type="date" class="form-control mb-3" asp-for="Order.OrderDate" />

        <button type="submit" class="btn btn-primary w-100">Update Order</button>
    </div>
</form>

