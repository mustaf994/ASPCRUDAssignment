@page
@model CreateModel

<h1>Create Order</h1>
<form method="post">
<div class="mt-3 card mb-3 p-3">
        <input type="text" placeholder="Enter Customer Name" class="form-control mb-3"  asp-for="CustomerName"/>
        <input type="text" placeholder="Enter Product Name" class="form-control mb-3" asp-for="ProductName"/>
        <input type="number" placeholder="Enter Quantity" class="form-control mb-3"  asp-for="Quantity"/>
        <input type="number" step="0.01" placeholder="Enter Price" class="form-control mb-3"  asp-for="Price"/>
        <input type="date" class="form-control mb-3"  asp-for="OrderDate"/>
<button type="submit" class="btn btn-primary w-100">Create Order</button>
</div>
</form>

